generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  customer
  admin
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         UserRole      @default(customer)
  avatarUrl    String?       @db.LongText
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  designs      SavedDesign[]
  favorites    Favorite[]
}

model SavedDesign {
  id         String   @id @default(cuid())
  title      String
  roomWidth  Int
  roomHeight Int
  roomShape  String
  wallColor  String
  floorColor String
  itemCount  Int      @default(0)
  items      Json
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Favorite {
  id          String   @id @default(cuid())
  userId      String
  productSlug String
  productName String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productSlug])
}